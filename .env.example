# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=
PORT=
PREFIX=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=
FRONTEND_URL=

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_NAME=

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=
JWT_REFRESH_EXPIRY=

# ─── OAuth — Google ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL=""

# ─── AWS S3 (Music Storage) ───────────────────────────────────────────────────
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_BUCKET=
AWS_REGION=
AWS_S3_PRESIGNED_URL_EXPIRY=3600

# ─── yt-dlp / ffmpeg ─────────────────────────────────────────────────────────
YTDLP_PATH=yt-dlp
YTDLP_TEMP_DIR=/tmp/sajilo-khata-audio
FFMPEG_PATH=ffmpeg

# ─── Music / Last.fm ──────────────────────────────────────────────────────────
LASTFM_API_KEY=
LASTFM_BASE_URL=https://ws.audioscrobbler.com/2.0
